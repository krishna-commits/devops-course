# DevOps World — Next.js static export (TypeScript, Tailwind)
# https://help.github.com/articles/ignoring-files/

# ─── Dependencies ───────────────────────────────────────────────────────────
node_modules/
/.pnp
.pnp.*
.pnp.js

# Yarn Berry
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# pnpm
.pnpm-store/

# ─── Next.js ────────────────────────────────────────────────────────────────
/.next/
/out/
/.swc/

# ─── Build & caches ─────────────────────────────────────────────────────────
/build
/dist
.turbo
.parcel-cache
.cache
.eslintcache
.stylelintcache
*.tsbuildinfo

# ─── Environment & secrets (never commit) ───────────────────────────────────
.env
.env.*
!.env.example
!.env*.example

# Keys, certs, credentials
*.pem
*.key
*.p12
*.pfx
*.crt.local
credentials.json
secrets.json
service-account*.json
*.keystore

# ─── Testing & coverage ─────────────────────────────────────────────────────
/coverage
*.lcov
.nyc_output
/playwright-report
/test-results
/blob-report
/playwright/.cache

# ─── Hosting & deploy tooling ───────────────────────────────────────────────
.vercel
.netlify
.wrangler
.firebase/
.serverless/

# ─── Logs & debug ───────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*
*.log
logs/

# ─── OS junk ────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.stackdump

# ─── Editors & IDEs ─────────────────────────────────────────────────────────
.idea/
*.iml
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~
.project
.classpath
.settings/

# ─── Cursor / local agent state ─────────────────────────────────────────────
.cursor/
.cursorignore.local

# ─── Temp & local output ────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.temp
*.bak
*.orig
*.tgz
scripts/output/
